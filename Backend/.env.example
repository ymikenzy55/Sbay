# ---- Server ----
NODE_ENV=development
PORT=4000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Database ----
# Atlas connection string. NEVER commit the real value.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/sbay?retryWrites=true&w=majority

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ---- OAuth / social sign-in ----
# Google OAuth (web)
GOOGLE_CLIENT_ID=replace_with_google_web_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret_if_used

# Paystack
PAYSTACK_SECRET_KEY=sk_live_replace_with_live_secret_key
PAYSTACK_CALLBACK_URL=https://your-frontend-domain.vercel.app/payment-success

# Apple Sign In (web)
APPLE_CLIENT_ID=replace_with_apple_services_id
APPLE_TEAM_ID=replace_with_apple_team_id
APPLE_KEY_ID=replace_with_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_apple_p8_contents\n-----END PRIVATE KEY-----"
APPLE_REDIRECT_URI=https://your-backend-domain.onrender.com/api/auth/oauth/apple/callback

# ---- Paystack ----
PAYSTACK_SECRET_KEY=replace_with_paystack_secret_key
PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=replace_with_webhook_secret_if_used
PAYSTACK_CALLBACK_URL=https://your-frontend-domain.vercel.app/payment-success

# ---- Default admin (seeded on first boot if no admin exists) ----
# These can be rotated immediately after first login.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_NAME=Platform Admin

# ---- Admin panel obfuscation ----
# The admin API is mounted under this prefix. Keep it unguessable in production.
# Example: /api/_panel/c0d3a72b
ADMIN_API_PREFIX=/api/_panel/control

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
