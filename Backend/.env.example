# ---- Server ----
NODE_ENV=development
PORT=4000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Database ----
# Atlas connection string. NEVER commit the real value.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/sbay?retryWrites=true&w=majority

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ---- Default admin (seeded on first boot if no admin exists) ----
# These can be rotated immediately after first login.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_NAME=Platform Admin

# ---- Admin panel obfuscation ----
# The admin API is mounted under this prefix. Keep it unguessable in production.
# Example: /api/_panel/c0d3a72b
ADMIN_API_PREFIX=/api/_panel/control

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
