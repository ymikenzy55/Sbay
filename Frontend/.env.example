# Where the frontend reaches the backend. The backend mounts everything
# under /api, so include that segment here.
VITE_API_URL=http://localhost:4000/api

# Obfuscated admin API prefix — must match Backend/.env ADMIN_API_PREFIX.
VITE_ADMIN_API=http://localhost:4000/api/_panel/control

# Public OAuth client IDs / keys used by the browser.
VITE_GOOGLE_CLIENT_ID=replace_with_google_web_client_id
VITE_PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key
